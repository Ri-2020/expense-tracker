{
  "hosting": {
    "public": "frontend/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/expenses", "function": "api", "region": "asia-south1" },
      { "source": "/expenses/**", "function": "api", "region": "asia-south1" },
      { "source": "/health", "function": "api", "region": "asia-south1" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": [
    {
      "source": "backend",
      "codebase": "expense-tracker",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "tests",
        "*.test.js",
        "firebase-debug.log"
      ]
    }
  ],
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": false
    }
  }
}
